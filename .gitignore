# Home-Lab Git Ignore Policy

# Sensitive credentials & environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
secrets/
credentials/
*.pem
*.key
*.pub
*.p12
*.pfx
*.cert
*.crt
*.der
id_rsa
id_ecdsa
id_ed25519
id_dsa

# Configuration & local settings
*.local.json
/config/local.json
/config/secrets.json
config.private.json

# Logs and databases
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.sqlite
*.db

# Operating System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Dependency directories
node_modules/
jspm_packages/
web_stage/
.pnp
.pnp.js

# Build and distribution directories
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/

# Python Virtual Environments & cache
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.tox/
.coverage
htmlcov/

# Terraform / Infrastructure as Code local state
.terraform/
*.tfstate
*.tfstate.backup
.terraform.tfstate.lock.info
